DATABASE_URL="postgresql://user:password@localhost:5432/helpdesk"
BETTER_AUTH_SECRET=""  # Generate with: openssl rand -base64 32  (must be 32+ chars)
BETTER_AUTH_URL="http://localhost:3000"  # Production: your Railway service URL (e.g. https://helpdesk.up.railway.app)
CLIENT_URL="http://localhost:5173"       # Production: same as BETTER_AUTH_URL (single-origin deployment)
TRUSTED_ORIGINS="http://localhost:5173"  # Production: same as BETTER_AUTH_URL
NODE_ENV="development"                   # Set to "production" in Railway
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD=""  # Set to a strong password (min 12 characters) before seeding
PORT=3000
OPENAI_API_KEY=""  # From OpenAI dashboard → API Keys
SENDGRID_API_KEY=""  # From SendGrid dashboard → Settings → API Keys
SENDGRID_FROM_EMAIL=""  # The verified sender address (e.g. support@yourdomain.com)
SENTRY_DSN=""  # From Sentry → Project Settings → Client Keys (DSN)
SENTRY_ENVIRONMENT="development"  # Set to "production" in Railway
